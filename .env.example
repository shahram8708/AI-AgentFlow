# Flask Core
FLASK_ENV=development
FLASK_APP=wsgi.py
SECRET_KEY=replace-with-a-random-64-char-hex-value

# Required Infrastructure
DATABASE_URL=postgresql://username:password@localhost:5432/agentflow_db
REDIS_URL=redis://localhost:6379/0

# Required AI and Billing Keys
GOOGLE_API_KEY=replace-with-google-ai-studio-api-key
RAZORPAY_KEY_ID=rzp_test_replace_with_key_id
RAZORPAY_KEY_SECRET=replace-with-razorpay-key-secret

# Optional Razorpay
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

# Email Delivery Optional
MAIL_SERVER=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=apikey
MAIL_PASSWORD=replace-with-email-provider-secret
MAIL_DEFAULT_SENDER=noreply@agentflow.ai

# Google OAuth Optional
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

# Celery Optional Overrides
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Storage and Uploads
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Platform Defaults
OUTPUT_RETENTION_DEFAULT_DAYS=30
FRONTEND_URL=http://localhost:5000
CACHE_DEFAULT_TIMEOUT=300
APP_VERSION=1.0.0